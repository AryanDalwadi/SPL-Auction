# Copy this file to `.env` on your computer for local dev (never commit `.env`).
#
# Production: set VITE_AUCTIONEER_PIN in your host (Vercel / Netlify / etc.) and redeploy.
# The `.env.example` file in Git is NOT read by the build — only real env vars at build time.
#
# No spaces around `=`. No quotes needed for simple values.
VITE_AUCTIONEER_PIN=change-me-to-your-pin
